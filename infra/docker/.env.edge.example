# Copy into infra/docker/.env and merge with your Compose env. Mirrors **API + worker** `OPENBIKA_INGRESS_*` on the VPS.

# ── infra/docker Compose (Let’s Encrypt) ────────────────────────────────
OPENBIKA_TRAEFIK_ACME_EMAIL=your-address@yourdomain.example

# ─── Worker (+ API — keep identical for dashboard `workload.edge` hints) ───
OPENBIKA_TRAEFIK_ROUTING=true
OPENBIKA_INGRESS_FREE_DNS_ZONE=traefik.me

# VPS / routable IPv4 (Let’s Encrypt HTTP-01 must hit Traefik on this host).

OPENBIKA_INGRESS_PUBLIC_IPV4=auto

# Laptop + Docker Desktop only (WAN `auto` often won’t hairpin to local Traefik):

# OPENBIKA_INGRESS_PUBLIC_IPV4=loopback
# Omit owned-domain fields when relying on free DNS:
OPENBIKA_PUBLIC_BASE_DOMAIN=
OPENBIKA_EDGE_PUBLIC_BASE_DOMAIN=

# Optional (defaults work with repo compose):
# OPENBIKA_TRAEFIK_EDGE_NETWORK=openbika_edge
# OPENBIKA_TRAEFIK_CERT_RESOLVER=letsencrypt
# After Let’s Encrypt is healthy, optionally force nip hosts to HTTPS + redirect too:
# OPENBIKA_TRAEFIK_SECURE_INGRESS=true
