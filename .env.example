NODE_ENV=development
LOG_LEVEL=info
ENABLE_PRETTY_LOGS=true

DATABASE_URL=postgres://openbika:openbika@localhost:5432/openbika_control

API_HOST=localhost
API_PORT=8787
API_PUBLIC_URL=http://localhost:8787
WEB_ORIGIN=http://localhost:3000
BETTER_AUTH_URL=http://localhost:8787
BETTER_AUTH_SECRET=replace-with-at-least-32-characters

TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=openbika-control-plane

# nip.io/sslip workloads (needs Traefik `--profile edge` on :80 / :443)
# Laptop + Docker Desktop: use loopback so `*.127.0.0.1.nip.io` hits Traefik here; use `auto` on a VPS.

OPENBIKA_INGRESS_FREE_DNS_ZONE=nip.io
OPENBIKA_INGRESS_PUBLIC_IPV4=loopback
OPENBIKA_EDGE_PUBLIC_BASE_DOMAIN=
OPENBIKA_PUBLIC_BASE_DOMAIN=
OPENBIKA_TRAEFIK_ROUTING=true

# OPENBIKA_INGRESS_PUBLIC_IPV4=auto

# Local / owned-domain dev (disable nip/sslip lines above — leave FREE_DNS_ZONE unset):
# OPENBIKA_INGRESS_FREE_DNS_ZONE=
# OPENBIKA_INGRESS_PUBLIC_IPV4=
# OPENBIKA_EDGE_PUBLIC_BASE_DOMAIN=local.openbika.test
# OPENBIKA_PUBLIC_BASE_DOMAIN=local.openbika.test
# OPENBIKA_TRAEFIK_ROUTING=false

